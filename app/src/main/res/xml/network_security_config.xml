<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        允许 *.xjtu.edu.cn 的明文 HTTP 连接。
        学校多个子系统（jwapp/bkkq/card/rg.lib/gste/gmis/org）不支持 HTTPS，
        逐一枚举容易遗漏导致回归，使用通配符更稳妥。
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">xjtu.edu.cn</domain>
        <!-- 体育场馆预订服务器（纯 IP，无域名，HTTP only） -->
        <domain includeSubdomains="false">202.117.17.144</domain>
        <!-- Srun 校园网认证网关（XJTU_STU），通过 HTTP 直连即可 -->
        <domain includeSubdomains="false">10.6.18.2</domain>
    </domain-config>
</network-security-config>
